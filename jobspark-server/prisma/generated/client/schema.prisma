model MatchScore {
  id           String @id @default(cuid())
  jobId        String
  profileId    String
  score        Float // 0.0 to 1.0
  breakdown    Json // Storage for skillMatch, expMatch, etc.
  modelVersion String // For A/B testing models

  job     Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  profile JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([profileId, score(sort: Desc)])
  @@index([jobId, score(sort: Desc)])
}

model RecommendationLog {
  id      String   @id @default(cuid())
  userId  String
  jobId   String
  clicked Boolean  @default(false)
  applied Boolean  @default(false)
  shownAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model PlatformSnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique @default(now())
  totalUsers        Int
  totalJobs         Int
  totalApplications Int
  matchesGenerated  Int
}

model Application {
  id       String            @id @default(cuid())
  jobId    String
  seekerId String
  status   ApplicationStatus @default(PENDING)

  job    Job              @relation(fields: [jobId], references: [id])
  seeker JobSeekerProfile @relation(fields: [seekerId], references: [id])

  logs ApplicationStatusLog[]

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, seekerId]) // Prevent duplicate applications
}

model ApplicationStatusLog {
  id            String            @id @default(cuid())
  applicationId String
  status        ApplicationStatus
  reason        String?
  changedAt     DateTime          @default(now())
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  role          UserRole @default(JOB_SEEKER)

  // Soft delete support
  isDeleted Boolean   @default(false)
  status    String    @default("ACTIVE")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Profile links
  jobSeekerProfile JobSeekerProfile?
  recruiterProfile RecruiterProfile?

  // Authentication links
  sessions Session[]
  accounts Account[]

  // Networking
  sentConnections     Connection[]        @relation("SentConnections")
  receivedConnections Connection[]        @relation("ReceivedConnections")
  notifications       Notification[]
  recommendations     RecommendationLog[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Company {
  id          String  @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String? @db.Text
  industry    String
  size        String?
  location    String?

  recruiters RecruiterProfile[]
  jobs       Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  RECRUITER
  JOB_SEEKER
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum LocationType {
  REMOTE
  ONSITE
  HYBRID
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  INTERVIEWING
  OFFERED
  REJECTED
  WITHDRAWN
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Job {
  id              String          @id @default(cuid())
  title           String
  description     String          @db.Text
  status          JobStatus       @default(DRAFT)
  type            JobType         @default(FULL_TIME)
  locationType    LocationType    @default(ONSITE)
  experienceLevel ExperienceLevel @default(ENTRY)

  salaryMin Int?
  salaryMax Int?
  location  String?

  // Analytics denormalization
  applicationCount Int @default(0)
  viewCount        Int @default(0)

  // Relations
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id])

  skills          JobSkill[]
  applications    Application[]
  matchScores     MatchScore[]
  recommendations RecommendationLog[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, type, locationType])
  @@index([companyId])
  @@index([recruiterId])
}

model Skill {
  id         String           @id @default(cuid())
  name       String           @unique
  jobs       JobSkill[]
  candidates CandidateSkill[]
}

model JobSkill {
  jobId      String
  skillId    String
  isRequired Boolean @default(true)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model CandidateSkill {
  profileId String
  skillId   String
  level     Int              @default(1) // 1-5
  yearsExp  Int              @default(0)
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
}

model Connection {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)

  sender   User @relation("SentConnections", fields: [senderId], references: [id])
  receiver User @relation("ReceivedConnections", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "APPLICATION_UPDATE", "NEW_MATCH", "CONNECTION_REQ"
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model JobSeekerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline           String?
  bio                String?
  resumeUrl          String?
  preferredSalaryMin Int?
  preferredSalaryMax Int?
  isProfileComplete  Boolean @default(false)

  // Normalized relations
  workExperience WorkExperience[]
  education      Education[]
  skills         CandidateSkill[]
  applications   Application[]
  matchScores    MatchScore[]

  @@index([userId])
}

model RecruiterProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  position  String?

  jobs Job[]

  @@index([companyId])
}

model WorkExperience {
  id        String           @id @default(cuid())
  profileId String
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  companyName String
  title       String
  startDate   DateTime
  endDate     DateTime?
  description String?   @db.Text

  @@index([profileId])
}

model Education {
  id        String           @id @default(cuid())
  profileId String
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  school    String
  degree    String
  field     String
  startDate DateTime
  endDate   DateTime?

  @@index([profileId])
}

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}
