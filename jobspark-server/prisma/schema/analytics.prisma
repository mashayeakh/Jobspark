model PlatformSnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique @default(now())
  totalUsers        Int
  totalJobs         Int
  totalApplications Int
  matchesGenerated  Int
}

model AnalyticsLog {
  id        String   @id @default(cuid())
  event     String
  metadata  Json?
  userId    String?
  timestamp DateTime @default(now())
}
