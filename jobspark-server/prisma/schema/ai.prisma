model MatchScore {
  id           String           @id @default(cuid())
  jobId        String
  profileId    String
  score        Float
  breakdown    Json
  modelVersion String
  createdAt    DateTime         @default(now())
  job          Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  profile      JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, score(sort: Desc)])
  @@index([jobId, score(sort: Desc)])
}

model RecommendationLog {
  id      String   @id @default(cuid())
  userId  String
  jobId   String
  clicked Boolean  @default(false)
  applied Boolean  @default(false)
  shownAt DateTime @default(now())
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportSession {
  id        String         @id @default(cuid())
  userId    String?
  status    String         @default("ACTIVE")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  ChatMessage[]
  user      User?          @relation(fields: [userId], references: [id])
  ticket    SupportTicket?
}

model ChatMessage {
  id         String         @id @default(cuid())
  sessionId  String
  message    String
  isUser     Boolean
  intent     String?
  confidence Float?
  timestamp  DateTime       @default(now())
  session    SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String         @id @default(cuid())
  sessionId String         @unique
  userId    String?
  reason    String
  status    String         @default("OPEN")
  priority  String         @default("NORMAL")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  session   SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id])
}

model KnowledgeBaseArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemAnomaly {
  id          String   @id @default(cuid())
  type        String
  severity    String
  description String
  source      String
  metrics     Json?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemMetric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  unit      String
  timestamp DateTime @default(now())
}
