model Application {
  id         String                 @id @default(cuid())
  jobId      String
  seekerId   String
  status     ApplicationStatus      @default(PENDING)
  appliedAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  job             Job                    @relation(fields: [jobId], references: [id])
  seeker          JobSeekerProfile       @relation(fields: [seekerId], references: [id])
  pipelineStageId String?
  pipelineStage   PipelineStage?         @relation(fields: [pipelineStageId], references: [id])
  logs            ApplicationStatusLog[]
  interviews      Interview[]

  @@unique([jobId, seekerId])
  @@index([pipelineStageId])
}

model ApplicationStatusLog {
  id            String            @id @default(cuid())
  applicationId String
  status        ApplicationStatus
  reason        String?
  changedAt     DateTime          @default(now())
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
