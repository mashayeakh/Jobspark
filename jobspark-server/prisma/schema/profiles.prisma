model JobSeekerProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  headline           String?
  bio                String?
  resumeUrl          String?
  preferredSalaryMin Int?
  preferredSalaryMax Int?
  isProfileComplete  Boolean          @default(false)
  views              Int              @default(0)
  name               String
  location           String?
  linkedinUrl        String?
  websiteUrl         String?
  openToNetworking   Boolean          @default(false)
  openToAdvising     Boolean          @default(false)
  expertise          String[]
  interests          String[]
  applications       Application[]
  skills             CandidateSkill[]
  education          Education[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchScores        MatchScore[]
  savedJobs          SavedJob[]       @relation("SavedJobToSeeker")
  workExperience     WorkExperience[]

  @@index([userId])
}

model RecruiterProfile {
  id          String      @id @default(cuid())
  userId      String      @unique
  companyId   String
  position    String?
  name        String
  bio         String?
  phoneNumber String?
  jobs        Job[]
  company     Company     @relation(fields: [companyId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews  Interview[] @relation("InterviewToRecruiterProfile")

  @@index([companyId])
}

model WorkExperience {
  id          String           @id @default(cuid())
  profileId   String
  companyName String
  title       String
  startDate   DateTime
  endDate     DateTime?
  description String?
  profile     JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Education {
  id        String           @id @default(cuid())
  profileId String
  school    String
  degree    String
  field     String
  startDate DateTime
  endDate   DateTime?
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}
