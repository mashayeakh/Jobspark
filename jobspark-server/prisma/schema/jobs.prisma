model Job {
  id              String          @id @default(cuid())
  title           String
  description     String          @db.Text
  status          JobStatus       @default(OPEN)
  type            JobType         @default(FULL_TIME)   
  locationType    LocationType    @default(ONSITE)
  experienceLevel ExperienceLevel @default(ENTRY)
  benefits        String?         @db.Text
  vacancy         Int             @default(1)
  applicationDeadline DateTime?

  salaryMin Int?
  salaryMax Int?
  location  String?

  responsibilities String? @db.Text
  requirements     String? @db.Text

  // Analytics denormalization
  applicationCount Int @default(0)
  viewCount        Int @default(0)

  // Fraud detection fields
  fraudStatus       String? // 'SAFE', 'FLAGGED', 'UNDER_REVIEW'
  fraudScore        Float? // 0-100 risk score
  fraudFlaggedAt    DateTime? // When job was flagged for fraud
  fraudReviewedAt   DateTime? // When fraud review was completed
  fraudReviewedBy   String? // Who reviewed the fraud (admin ID)
  fraudReviewReason String? // Reason for fraud review decision
  fraudIssues       Json? // Array of fraud issues found

  // Relations
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id])

  skills          JobSkill[]
  applications    Application[]
  matchScores     MatchScore[]
  recommendations RecommendationLog[]

  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  category      Category?    @relation(fields: [categoryId], references: [id])
  categoryId    String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  subCategoryId String?
  workStyle     WorkStyle?   @relation(fields: [workStyleId], references: [id])
  workStyleId   Int?

  @@index([status, type, locationType])
  @@index([companyId])
  @@index([recruiterId])
}

model Skill {
  id         String           @id @default(cuid())
  name       String           @unique
  jobs       JobSkill[]
  candidates CandidateSkill[]
}

model JobSkill {
  jobId      String
  skillId    String
  isRequired Boolean @default(true)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model CandidateSkill {
  profileId String
  skillId   String
  level     Int              @default(1) // 1-5
  yearsExp  Int              @default(0)
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
}
