model Job {
  id                  String              @id @default(cuid())
  title               String
  description         String
  status              JobStatus           @default(OPEN)
  type                JobType             @default(FULL_TIME)
  locationType        LocationType        @default(ONSITE)
  experienceLevel     ExperienceLevel     @default(ENTRY)
  benefits            String?
  vacancy             Int                 @default(1)
  salaryMin           Int?
  salaryMax           Int?
  location            String?
  responsibilities    String?
  requirements        String?
  applicationCount    Int                 @default(0)
  viewCount           Int                 @default(0)
  fraudStatus         String?
  fraudScore          Float?
  fraudFlaggedAt      DateTime?
  fraudReviewedAt     DateTime?
  fraudReviewedBy     String?
  fraudReviewReason   String?
  fraudIssues         Json?
  companyId           String
  recruiterId         String
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  categoryId          String?
  subCategoryId       String?
  workStyleId         Int?
  applicationDeadline DateTime?
  applications        Application[]
  category            Category?           @relation(fields: [categoryId], references: [id])
  company             Company             @relation(fields: [companyId], references: [id])
  recruiter           RecruiterProfile    @relation(fields: [recruiterId], references: [id])
  subCategory         SubCategory?        @relation(fields: [subCategoryId], references: [id])
  workStyle           WorkStyle?          @relation(fields: [workStyleId], references: [id])
  skills              JobSkill[]
  matchScores         MatchScore[]
  recommendations     RecommendationLog[]
  savedBy             SavedJob[]          @relation("SavedJobToJob")

  @@index([status, type, locationType])
  @@index([companyId])
  @@index([recruiterId])
}

model Skill {
  id         String           @id @default(cuid())
  name       String           @unique
  candidates CandidateSkill[]
  jobs       JobSkill[]
}

model JobSkill {
  jobId      String
  skillId    String
  isRequired Boolean @default(true)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model CandidateSkill {
  profileId String
  skillId   String
  level     Int              @default(1)
  yearsExp  Int              @default(0)
  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
}

model SavedJob {
  id        String           @id @default(cuid())
  jobId     String
  seekerId  String
  createdAt DateTime         @default(now())
  job       Job              @relation("SavedJobToJob", fields: [jobId], references: [id], onDelete: Cascade)
  seeker    JobSeekerProfile @relation("SavedJobToSeeker", fields: [seekerId], references: [id], onDelete: Cascade)

  @@unique([jobId, seekerId])
  @@index([seekerId])
}
