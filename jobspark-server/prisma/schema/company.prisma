model Company {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String?  @db.Text
  industry    String
  size        String?
  location    String?
  
  recruiters  RecruiterProfile[]
  jobs        Job[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
