{
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": ".",                    
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",                    
    "paths": {                          
      "@/*": ["src/*"],
      "prisma/*": ["prisma/*"]
    }
  },
  "include": [
    "src/**/*", 
    "prisma/generated/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}