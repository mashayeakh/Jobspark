# Application
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend.vercel.app

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Authentication (Better Auth)
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=https://your-backend.onrender.com

# JWT Configuration
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Better Auth Session
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

# Admin Credentials
ADMIN_EMAIL=admin@jobspark.com
ADMIN_PASSWORD=admin_password

# External APIs (Uncomment if needed)
GEMINI_API_KEY=your_gemini_api_key
REDIS_URL=redis://localhost:6379
# EMAIL_SENDER_SMTP_USER=
# EMAIL_SENDER_SMTP_PASS=
# EMAIL_SENDER_SMTP_HOST=
# EMAIL_SENDER_SMTP_PORT=
# EMAIL_SENDER_SMTP_FROM=


CLOUDINARY_CLOUD_NAME=replace_with_prod_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_prod_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_prod_cloudinary_api_secret