<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Interview Invitation</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
            rel="stylesheet">
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background: #ECEEF2;
                font-family: 'Plus Jakarta Sans', sans-serif;
                padding: 40px 16px;
                -webkit-font-smoothing: antialiased;
            }

            .wrapper {
                max-width: 560px;
                margin: 0 auto;
            }

            /* ── TOP BAR ── */
            .topbar {
                background: #0F1117;
                border-radius: 12px 12px 0 0;
                padding: 16px 28px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 13px;
                font-weight: 600;
                color: #fff;
                letter-spacing: 0.03em;
            }

            .brand-dot {
                width: 22px;
                height: 22px;
                border-radius: 5px;
                background: linear-gradient(135deg, #E2B96A, #B8882E);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .topbar-tag {
                font-size: 11px;
                font-weight: 600;
                color: #E2B96A;
                letter-spacing: 0.1em;
                text-transform: uppercase;
            }

            /* ── HERO ── */
            .hero {
                background: linear-gradient(160deg, #141720 0%, #1C2033 100%);
                padding: 32px 36px 28px;
                position: relative;
                overflow: hidden;
            }

            .hero::after {
                content: '';
                position: absolute;
                right: -30px;
                top: -30px;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: radial-gradient(circle, #E2B96A08 0%, transparent 70%);
                pointer-events: none;
            }

            .hero-label {
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.16em;
                text-transform: uppercase;
                color: #E2B96A;
                margin-bottom: 8px;
            }

            .hero-title {
                font-size: 30px;
                font-weight: 700;
                color: #F4F1EA;
                line-height: 1.15;
                letter-spacing: -0.02em;
            }

            .hero-title span {
                color: #E2B96A;
                font-style: italic;
                font-weight: 300;
            }

            .hero-rule {
                width: 32px;
                height: 2px;
                background: linear-gradient(90deg, #E2B96A, transparent);
                margin-top: 16px;
            }

            /* ── GOLD STRIP ── */
            .gold-strip {
                height: 3px;
                background: linear-gradient(90deg, #B8882E 0%, #E2B96A 40%, #F0D080 70%, #B8882E 100%);
            }

            /* ── MAIN CARD ── */
            .card {
                background: #fff;
                padding: 32px 36px;
            }

            .greeting {
                font-size: 16px;
                font-weight: 600;
                color: #111318;
                margin-bottom: 10px;
            }

            .intro {
                font-size: 13.5px;
                color: #555B6E;
                line-height: 1.72;
                margin-bottom: 24px;
            }

            .intro strong {
                color: #111318;
                font-weight: 600;
            }

            .intro em {
                color: #8B6A20;
                font-style: italic;
                font-weight: 500;
            }

            /* ── DETAILS BOX ── */
            .details-box {
                border: 1px solid #E8EAF0;
                border-radius: 8px;
                overflow: hidden;
                margin-bottom: 24px;
            }

            .details-head {
                background: #F6F7FA;
                padding: 9px 16px;
                display: flex;
                align-items: center;
                gap: 7px;
                border-bottom: 1px solid #E8EAF0;
            }

            .details-head span {
                font-size: 10.5px;
                font-weight: 700;
                letter-spacing: 0.13em;
                text-transform: uppercase;
                color: #8B6A20;
            }

            .detail-row {
                display: flex;
                align-items: center;
                padding: 11px 16px;
                gap: 0;
                border-bottom: 1px solid #F0F1F5;
            }

            .detail-row:last-child {
                border-bottom: none;
            }

            .detail-icon {
                width: 26px;
                color: #C4A254;
                flex-shrink: 0;
                display: flex;
                align-items: center;
            }

            .detail-key {
                width: 86px;
                flex-shrink: 0;
                font-size: 10.5px;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: #9BA0B0;
            }

            .detail-val {
                font-size: 13.5px;
                font-weight: 500;
                color: #111318;
                flex: 1;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .badge {
                background: #EDFAF3;
                color: #1A7A45;
                border: 1px solid #B6E8CC;
                font-size: 10px;
                font-weight: 700;
                padding: 2px 9px;
                border-radius: 20px;
                letter-spacing: 0.04em;
            }

            /* ── CTA ── */
            .cta-wrap {
                text-align: center;
                margin-bottom: 22px;
            }

            .cta-label {
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: #9BA0B0;
                margin-bottom: 12px;
            }

            .cta-btn {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: #0F1117;
                color: #F4F1EA;
                text-decoration: none;
                padding: 12px 30px;
                border-radius: 6px;
                font-size: 13px;
                font-weight: 600;
                letter-spacing: 0.04em;
                border-left: 3px solid #E2B96A;
            }

            .cta-or {
                margin: 12px 0 6px;
                font-size: 11px;
                color: #C0C4D0;
            }

            .cta-copy {
                font-size: 12.5px;
                font-weight: 500;
                color: #8B6A20;
                text-decoration: none;
            }

            .cta-copy:hover {
                text-decoration: underline;
            }

            /* ── NOTE ── */
            .note {
                background: #FAFAFA;
                border: 1px solid #E8EAF0;
                border-left: 3px solid #E2B96A;
                border-radius: 0 6px 6px 0;
                padding: 12px 14px;
                margin-bottom: 24px;
                font-size: 13px;
                color: #555B6E;
                line-height: 1.65;
                display: flex;
                gap: 9px;
                align-items: flex-start;
            }

            .note svg {
                flex-shrink: 0;
                margin-top: 1px;
                color: #C4A254;
            }

            /* ── CLOSING ── */
            .closing {
                font-size: 13px;
                color: #555B6E;
                line-height: 1.7;
                padding-top: 18px;
                border-top: 1px solid #F0F1F5;
            }

            /* ── FOOTER ── */
            .footer {
                background: #F6F7FA;
                border: 1px solid #E8EAF0;
                border-top: none;
                border-radius: 0 0 12px 12px;
                padding: 18px 36px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
            }

            .footer-left {
                font-size: 13px;
                color: #111318;
                font-weight: 500;
                line-height: 1.5;
            }

            .footer-left span {
                display: block;
                font-size: 11.5px;
                color: #9BA0B0;
                font-weight: 400;
                margin-top: 1px;
            }

            .footer-right {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 11px;
                font-weight: 600;
                color: #9BA0B0;
                letter-spacing: 0.07em;
                text-transform: uppercase;
                white-space: nowrap;
            }

            .footer-dot {
                width: 18px;
                height: 18px;
                border-radius: 4px;
                background: linear-gradient(135deg, #E2B96A, #B8882E);
                display: flex;
                align-items: center;
                justify-content: center;
            }
        </style>
    </head>

    <body>
        <div class="wrapper">

            <!-- Top Bar -->
            <div class="topbar">
                <div class="brand">
                    <div class="brand-dot">
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                            <path d="M2 8L5 2l3 6H2z" fill="#FFF8E8" />
                        </svg>
                    </div>
                    JobSpark
                </div>
                <div class="topbar-tag">Interview Invitation</div>
            </div>

            <!-- Hero -->
            <div class="hero">
                <div class="hero-label">Congratulations</div>
                <div class="hero-title">You've been<br><span>selected.</span></div>
                <div class="hero-rule"></div>
            </div>
            <div class="gold-strip"></div>

            <!-- Card -->
            <div class="card">

                <div class="greeting">Dear <%= name %>,</div>
                <p class="intro">
                    We are delighted to inform you that <strong>
                        <%= companyName %>
                    </strong> has reviewed your application and would like to invite you to interview for the position
                    of <em>
                        <%= jobTitle %>
                    </em>. Your background has impressed our team and we look forward to learning more about you.
                </p>

                <!-- Interview Details -->
                <div class="details-box">
                    <div class="details-head">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#C4A254" stroke-width="1.6">
                            <rect x="1" y="1.5" width="10" height="9" rx="1.5" />
                            <path d="M4 1.5V.5M8 1.5V.5" />
                            <line x1="1" y1="5" x2="11" y2="5" />
                        </svg>
                        <span>Interview Details</span>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <rect x="1" y="3" width="8" height="9" rx="1.5" />
                                <path d="M9 5.5l4-1.5v6l-4-1.5" />
                            </svg>
                        </div>
                        <div class="detail-key">Format</div>
                        <div class="detail-val">
                            <%= interviewType %> Interview
                                <span class="badge">Confirmed</span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <rect x="1" y="2" width="12" height="11" rx="1.5" />
                                <path d="M5 2V1M9 2V1" />
                                <line x1="1" y1="5.5" x2="13" y2="5.5" />
                            </svg>
                        </div>
                        <div class="detail-key">Date</div>
                        <div class="detail-val">
                            <%= date %>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <circle cx="7" cy="7" r="5.5" />
                                <path d="M7 4v3l2 2" />
                            </svg>
                        </div>
                        <div class="detail-key">Time</div>
                        <div class="detail-val">
                            <%= time %>
                                <span style="color:#9BA0B0;font-weight:400;font-size:12px">(UTC)</span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <path d="M7 1C4.79 1 3 2.79 3 5c0 3.5 4 8 4 8s4-4.5 4-8c0-2.21-1.79-4-4-4z" />
                                <circle cx="7" cy="5" r="1.4" />
                            </svg>
                        </div>
                        <div class="detail-key">Location</div>
                        <div class="detail-val">
                            <%= location %>
                        </div>
                    </div>

                </div>

                <!-- CTA Button -->
                <% if (meetingLink) { %>
                    <div class="cta-wrap">
                        <div class="cta-label">Join at the scheduled time</div>
                        <a href="<%= meetingLink %>" class="cta-btn">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.6">
                                <rect x="1" y="3.5" width="8" height="7" rx="1.5" />
                                <path d="M9 6l4-1.5v5L9 8" />
                            </svg>
                            Join Video Call
                        </a>
                        <div class="cta-or">or</div>
                        <a href="<%= meetingLink %>" class="cta-copy">Copy meeting link →</a>
                    </div>
                    <% } %>

                        <!-- Note -->
                        <div class="note">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <circle cx="7" cy="7" r="5.5" />
                                <path d="M7 6v4M7 4.5v.3" />
                            </svg>
                            <%= nextSteps
                                || "Please ensure you have a stable internet connection and a quiet environment. We recommend joining 2–3 minutes early. To reschedule, please contact us at least 24 hours in advance."
                                %>
                        </div>

                        <!-- Closing -->
                        <p class="closing">
                            We look forward to our conversation. Should you have any questions before the interview,
                            please don't hesitate to reach out. We want you to feel fully prepared and confident.
                        </p>

            </div>

            <!-- Footer -->
            <div class="footer">
                <div class="footer-left">
                    The <%= companyName %> Team
                        <span>This invitation was sent on behalf of <%= companyName %>.</span>
                </div>
                <div class="footer-right">
                    <div class="footer-dot">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
                            <path d="M1.5 7L4 2l2.5 5H1.5z" fill="#FFF8E8" />
                        </svg>
                    </div>
                    Sent via JobSpark
                </div>
            </div>

        </div>
    </body>

</html>